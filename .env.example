# ============================================================
# Article Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# --- LLM Provider API Keys (fill only the one you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- GitHub ---
GITHUB_TOKEN=

# --- Cloudflare Pages (for CI/CD — set as GitHub Secrets too) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
